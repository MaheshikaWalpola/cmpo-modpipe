@prefix cmpo:    <https://vsr.informatik.tu-chemnitz.de/ontologies/cmpo#> .
@prefix sosa:    <http://www.w3.org/ns/sosa/> .
@prefix ssn:     <http://www.w3.org/ns/ssn/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt:    <http://qudt.org/schema/qudt/> .
@prefix unit:    <http://qudt.org/vocab/unit/> .
@prefix dcterms: <http://purl.org/dc/terms/> .

#################################################################
### CMPO v2.0 — Chemical-Mechanical Planarization Process Ontology
###
### SOSA/SSN-aligned core: every sensor reading is modeled as one
### sosa:Observation that links
###   sosa:observedProperty   -> a cmpo observable property (e.g. cmpo:RetainingRingPressure)
###   sosa:hasFeatureOfInterest -> the thing measured (e.g. a cmpo:Wafer or cmpo:PolishingStep)
###   sosa:madeBySensor / cmpo:madeOnPlatform -> the tool or component that produced the value
###   sosa:hasSimpleResult    -> the numeric value (xsd:float)
###   sosa:resultTime         -> the timestamp (xsd:dateTime; raw epoch kept in cmpo:rawTimestamp)
###
### Example (PHM 2016 CSV row: PRESSURIZED_CHAMBER_PRESSURE = 67.14,
### wafer 371447024, timestamp 481637082, stage A, machine 4):
###   :obs_00001 a cmpo:CMPObservation ;
###       sosa:observedProperty    cmpo:PressurizedChamberPressure ;
###       sosa:hasFeatureOfInterest :wafer_371447024 ;
###       cmpo:madeOnPlatform      :machine_4 ;
###       cmpo:duringStep          :step_A_371447024 ;
###       sosa:hasSimpleResult     "67.14"^^xsd:float ;
###       cmpo:rawTimestamp        "481637082"^^xsd:decimal .
###
### Design decisions:
###  - SOSA/SSN is the backbone (W3C sensor-observation standard).
###  - BFO anchors are NOT in this file; they live in the separate
###    alignment module cmpo-bfo-alignment.ttl.
###  - SOSA/SSN terms are referenced, not owl:import-ed, to keep
###    triple-store loading self-contained.
###  - Naming: UpperCamelCase classes, lowerCamelCase properties.
###  - PHM 2016 CSV column names are preserved as skos:altLabel on the
###    corresponding observable properties for NL-retrieval grounding.
###
### CHANGELOG v2.0.1 (2026-07-14, patch — no term added, removed or renamed):
###  P1  skos:altLabel grounding added for the 5 PHM 2016 context/identifier
###      headers that had matching terms but no altLabel:
###      MACHINE_ID -> cmpo:toolId, TIMESTAMP -> cmpo:rawTimestamp,
###      WAFER_ID -> cmpo:hasWaferId, STAGE -> cmpo:stageLabel,
###      CHAMBER -> cmpo:chamberNumber. All 28 PHM headers now ground via altLabel.
###  P2  owl:minCardinality literal on cmpo:Carrier retyped
###      xsd:integer -> xsd:nonNegativeInteger (OWL 2 conformance).
###  P3  cmpo:NanometerPerMinute aligned to QUDT via owl:sameAs unit:NanoM-PER-MIN.
###  P4  Design note documented: CMP parameter classes are used in individual
###      positions (sosa:observedProperty targets, cmpo:canonicalUnit subjects)
###      by OWL 2 class-individual punning. This is intentional.
###
### CHANGELOG v2.0.2 (2026-07-23, patch):
###  P5  cmpo:madeOnPlatform declared as an owl:ObjectProperty. The property
###      was used by the pipeline and documented in the header comments but
###      (erroneously, under the sosa: prefix) never declared: madeOnPlatform
###      is not a SOSA/SSN term. It is a CMP-specific extension linking an
###      observation directly to the tool or chamber, because PHM 2016 logs
###      name equipment, not individual sensors. All data and documentation
###      renamed from sosa:madeOnPlatform to cmpo:madeOnPlatform.
#################################################################

<https://vsr.informatik.tu-chemnitz.de/ontologies/cmpo> a owl:Ontology ;
    rdfs:label "CMP Process Ontology (CMPO)"@en ;
    rdfs:comment "Domain ontology for Chemical-Mechanical Planarization (CMP) process data, aligned with the W3C SOSA/SSN sensor-observation standard. Models wafers, tools, tool components, consumables, process steps, recipes and observable process parameters for industrial CMP knowledge graphs, including the PHM 2016 Data Challenge dataset."@en ;
    owl:versionInfo "2.0.2 (frozen; patch of 2.0, see changelog)" ;
    dcterms:modified "2026-07-23"^^xsd:date ;
    dcterms:creator "Maheshika Hansamalee Walpola, Professorship VSR, TU Chemnitz" ;
    dcterms:created "2026-07-08"^^xsd:date ;
    rdfs:seeAlso <http://www.w3.org/ns/sosa/> .

#################################################################
### 1. OBSERVATION CORE (SOSA backbone)
#################################################################

cmpo:CMPObservation a owl:Class ;
    rdfs:subClassOf sosa:Observation ;
    rdfs:label "CMP Observation"@en ;
    rdfs:comment "A single recorded measurement from the CMP process: one value of one observable property (e.g. a pressure or rotation speed) for one feature of interest at one point in time. Corresponds to one cell of a PHM 2016 CSV row."@en .

cmpo:duringStep a owl:ObjectProperty ;
    rdfs:label "during step"@en ;
    rdfs:domain cmpo:CMPObservation ;
    rdfs:range cmpo:PolishingStep ;
    rdfs:comment "Links an observation to the polishing step during which it was recorded. Complements sosa:hasFeatureOfInterest when the feature is the wafer rather than the step."@en .

cmpo:rawTimestamp a owl:DatatypeProperty ;
    skos:altLabel "TIMESTAMP"@en ;
    rdfs:label "raw timestamp"@en ;
    rdfs:domain cmpo:CMPObservation ;
    rdfs:range xsd:decimal ;
    rdfs:comment "The original numeric (epoch-style) timestamp exactly as recorded in the source CSV, kept alongside the ISO sosa:resultTime for lossless traceability."@en .

cmpo:CMPSensor a owl:Class ;
    rdfs:subClassOf sosa:Sensor ;
    rdfs:label "CMP Sensor"@en ;
    rdfs:comment "A sensing device on a CMP tool that produces observations (e.g. a pressure transducer in a carrier zone or a flow meter in a slurry line). Used when the concrete sensor is known; PHM 2016 data does not name individual sensors, so observations may instead link directly to the tool via cmpo:madeOnPlatform."@en .

#################################################################
### 2. OBSERVABLE PROPERTIES (what is measured)
### One canonical hierarchy under sosa:ObservableProperty.
### PHM 2016 CSV column names appear as skos:altLabel.
#################################################################

cmpo:CMPParameter a owl:Class ;
    rdfs:subClassOf sosa:ObservableProperty ;
    rdfs:label "CMP Parameter"@en ;
    rdfs:comment "A measurable CMP process parameter. Root of the observable-property hierarchy; every observation observes exactly one subclass instance of this class."@en .

cmpo:canonicalUnit a owl:ObjectProperty ;
    rdfs:label "canonical unit"@en ;
    rdfs:domain cmpo:CMPParameter ;
    rdfs:range cmpo:Unit ;
    rdfs:comment "The default measurement unit in which values of this parameter are recorded (e.g. psi for pressures, rpm for rotation speeds)."@en .

### 2.1 Pressure parameters

cmpo:Pressure a owl:Class ;
    rdfs:subClassOf cmpo:CMPParameter ;
    rdfs:label "Pressure"@en ;
    rdfs:comment "Pressure-related CMP parameters, normally measured in psi or bar. Parent of all carrier-zone and chamber pressure signals."@en .

cmpo:RetainingRingPressure a owl:Class ;
    rdfs:subClassOf cmpo:Pressure ;
    rdfs:label "Retaining Ring Pressure"@en ;
    skos:altLabel "RETAINER_RING_PRESSURE"@en ;
    rdfs:comment "Pressure applied by the retaining ring zone of the carrier, holding the wafer in place at its edge during polishing."@en .

cmpo:MainOuterAirBagPressure a owl:Class ;
    rdfs:subClassOf cmpo:Pressure ;
    rdfs:label "Main Outer Air Bag Pressure"@en ;
    skos:altLabel "MAIN_OUTER_AIR_BAG_PRESSURE"@en ;
    rdfs:comment "Pressure in the main outer air-bag zone of the carrier membrane, controlling downforce on the outer wafer region."@en .

cmpo:CenterAirBagPressure a owl:Class ;
    rdfs:subClassOf cmpo:Pressure ;
    rdfs:label "Center Air Bag Pressure"@en ;
    skos:altLabel "CENTER_AIR_BAG_PRESSURE"@en ;
    rdfs:comment "Pressure in the center air-bag zone of the carrier membrane, controlling downforce at the wafer center."@en .

cmpo:RippleAirBagPressure a owl:Class ;
    rdfs:subClassOf cmpo:Pressure ;
    rdfs:label "Ripple Air Bag Pressure"@en ;
    skos:altLabel "RIPPLE_AIR_BAG_PRESSURE"@en ;
    rdfs:comment "Pressure in the ripple air-bag zone of the carrier membrane, an intermediate annular pressure zone."@en .

cmpo:EdgeAirBagPressure a owl:Class ;
    rdfs:subClassOf cmpo:Pressure ;
    rdfs:label "Edge Air Bag Pressure"@en ;
    skos:altLabel "EDGE_AIR_BAG_PRESSURE"@en ;
    rdfs:comment "Pressure in the edge air-bag zone of the carrier membrane, controlling downforce at the wafer edge to counteract edge non-uniformity."@en .

cmpo:PressurizedChamberPressure a owl:Class ;
    rdfs:subClassOf cmpo:Pressure ;
    rdfs:label "Pressurized Chamber Pressure"@en ;
    skos:altLabel "PRESSURIZED_CHAMBER_PRESSURE"@en ;
    rdfs:comment "Pressure of the pressurized chamber in the carrier head assembly during polishing."@en .

cmpo:ContactPressure a owl:Class ;
    rdfs:subClassOf cmpo:Pressure ;
    rdfs:label "Contact Pressure"@en ;
    rdfs:comment "Pressure exerted at the wafer-pad interface, calculated from downforce and contact area. A derived quantity central to Preston's law."@en .

cmpo:Downforce a owl:Class ;
    rdfs:subClassOf cmpo:Pressure ;
    rdfs:label "Downforce"@en ;
    rdfs:comment "Vertical force applied by the carrier head on the wafer during polishing, typically measured in Newtons."@en .

### 2.2 Velocity parameters

cmpo:Velocity a owl:Class ;
    rdfs:subClassOf cmpo:CMPParameter ;
    rdfs:label "Velocity"@en ;
    skos:altLabel "Rotation Speed"@en ;
    rdfs:comment "Rotational or relative velocity parameters used in CMP, normally measured in rpm or m/s."@en .

cmpo:PlatenRotationSpeed a owl:Class ;
    rdfs:subClassOf cmpo:Velocity ;
    rdfs:label "Platen Rotation Speed"@en ;
    skos:altLabel "STAGE_ROTATION"@en ;
    skos:altLabel "Stage Rotation"@en ;
    skos:altLabel "Polishing Table Rotation"@en ;
    rdfs:comment "Rotation speed of the platen (polishing table) in rpm. Appears as Stage Rotation in the PHM 2016 dataset."@en .

cmpo:CarrierRotationSpeed a owl:Class ;
    rdfs:subClassOf cmpo:Velocity ;
    rdfs:label "Carrier Rotation Speed"@en ;
    skos:altLabel "HEAD_ROTATION"@en ;
    skos:altLabel "Head Rotation"@en ;
    skos:altLabel "Head Speed"@en ;
    skos:altLabel "Carrier RPM"@en ;
    rdfs:comment "Rotation speed of the carrier (polishing head) in rpm. Appears as Head Rotation in the PHM 2016 dataset."@en .

cmpo:WaferRotationSpeed a owl:Class ;
    rdfs:subClassOf cmpo:Velocity ;
    rdfs:label "Wafer Rotation Speed"@en ;
    skos:altLabel "WAFER_ROTATION"@en ;
    rdfs:comment "Rotation speed of the wafer itself during polishing, in rpm."@en .

cmpo:RelativeVelocity a owl:Class ;
    rdfs:subClassOf cmpo:Velocity ;
    rdfs:label "Relative Velocity"@en ;
    rdfs:comment "Relative velocity between the wafer and polishing pad surface, calculated from platen and carrier rotation speeds, measured in m/s. The V term of Preston's law."@en .

### 2.3 Slurry flow parameters

cmpo:SlurryFlowRate a owl:Class ;
    rdfs:subClassOf cmpo:CMPParameter ;
    rdfs:label "Slurry Flow Rate"@en ;
    skos:altLabel "Slurry Flow"@en ;
    rdfs:comment "Slurry delivery flow-rate parameters, normally measured in ml/min. Parent of the per-line flow signals."@en .

cmpo:SlurryFlowLineA a owl:Class ;
    rdfs:subClassOf cmpo:SlurryFlowRate ;
    rdfs:label "Slurry Flow Line A"@en ;
    skos:altLabel "SLURRY_FLOW_LINE_A"@en ;
    rdfs:comment "Slurry flow rate measured on slurry delivery line A."@en .

cmpo:SlurryFlowLineB a owl:Class ;
    rdfs:subClassOf cmpo:SlurryFlowRate ;
    rdfs:label "Slurry Flow Line B"@en ;
    skos:altLabel "SLURRY_FLOW_LINE_B"@en ;
    rdfs:comment "Slurry flow rate measured on slurry delivery line B."@en .

cmpo:SlurryFlowLineC a owl:Class ;
    rdfs:subClassOf cmpo:SlurryFlowRate ;
    rdfs:label "Slurry Flow Line C"@en ;
    skos:altLabel "SLURRY_FLOW_LINE_C"@en ;
    rdfs:comment "Slurry flow rate measured on slurry delivery line C."@en .

### 2.4 Conditioning parameters

cmpo:ConditioningParameter a owl:Class ;
    rdfs:subClassOf cmpo:CMPParameter ;
    rdfs:label "Conditioning Parameter"@en ;
    skos:altLabel "Conditioning"@en ;
    rdfs:comment "Pad-conditioning parameters such as dresser usage, dressing water status, sweep rate and conditioning force."@en .

cmpo:DresserUsage a owl:Class ;
    rdfs:subClassOf cmpo:ConditioningParameter ;
    rdfs:label "Dresser Usage"@en ;
    skos:altLabel "USAGE_OF_DRESSER"@en ;
    skos:altLabel "Usage Of Dresser"@en ;
    rdfs:comment "Accumulated usage of the dresser (conditioner), an indicator of conditioner disc wear."@en .

cmpo:DressingWaterStatus a owl:Class ;
    rdfs:subClassOf cmpo:ConditioningParameter ;
    rdfs:label "Dressing Water Status"@en ;
    skos:altLabel "DRESSING_WATER_STATUS"@en ;
    skos:altLabel "Conditioner Rinse Water"@en ;
    rdfs:comment "Amount or status of deionized water used for rinsing and cooling the dresser/conditioner at the conditioner table."@en .

cmpo:ConditioningSweepRate a owl:Class ;
    rdfs:subClassOf cmpo:ConditioningParameter ;
    rdfs:label "Conditioning Sweep Rate"@en ;
    rdfs:comment "Frequency of the conditioner arm movement across the pad, measured in sweeps per minute."@en .

cmpo:ConditioningForce a owl:Class ;
    rdfs:subClassOf cmpo:ConditioningParameter ;
    rdfs:label "Conditioning Force"@en ;
    rdfs:comment "Normal force applied by the conditioner disc on the polishing pad surface, in Newtons. Higher force increases pad surface renewal rate."@en .

cmpo:ConditioningRatio a owl:Class ;
    rdfs:subClassOf cmpo:ConditioningParameter ;
    rdfs:label "Conditioning Ratio"@en ;
    rdfs:comment "Ratio of total conditioning time to total polishing time within a run (%). Higher ratio means more aggressive pad renewal."@en .

### 2.5 Usage / lifetime parameters

cmpo:UsageParameter a owl:Class ;
    rdfs:subClassOf cmpo:CMPParameter ;
    rdfs:label "Usage Parameter"@en ;
    skos:altLabel "Pad Lifetime"@en ;
    rdfs:comment "Usage and lifetime tracking parameters for consumables such as pads, dresser tables, backing films, membranes and pressurized sheets."@en .

cmpo:DresserTableUsage a owl:Class ;
    rdfs:subClassOf cmpo:UsageParameter ;
    rdfs:label "Dresser Table Usage"@en ;
    skos:altLabel "USAGE_OF_DRESSER_TABLE"@en ;
    rdfs:comment "Accumulated usage of the dresser (conditioner) table."@en .

cmpo:PolishingTableUsage a owl:Class ;
    rdfs:subClassOf cmpo:UsageParameter ;
    rdfs:label "Polishing Table Usage"@en ;
    skos:altLabel "USAGE_OF_POLISHING_TABLE"@en ;
    rdfs:comment "Accumulated usage of the polishing table (platen), an indicator of pad wear on that platen."@en .

cmpo:BackingFilmUsage a owl:Class ;
    rdfs:subClassOf cmpo:UsageParameter ;
    rdfs:label "Backing Film Usage"@en ;
    skos:altLabel "USAGE_OF_BACKING_FILM"@en ;
    rdfs:comment "Accumulated usage of the carrier backing film."@en .

cmpo:MembraneUsage a owl:Class ;
    rdfs:subClassOf cmpo:UsageParameter ;
    rdfs:label "Membrane Usage"@en ;
    skos:altLabel "USAGE_OF_MEMBRANE"@en ;
    rdfs:comment "Accumulated usage of the carrier membrane."@en .

cmpo:PressurizedSheetUsage a owl:Class ;
    rdfs:subClassOf cmpo:UsageParameter ;
    rdfs:label "Pressurized Sheet Usage"@en ;
    skos:altLabel "USAGE_OF_PRESSURIZED_SHEET"@en ;
    rdfs:comment "Accumulated usage of the carrier pressurized sheet."@en .

### 2.6 Material removal parameters

cmpo:MaterialRemovalRate a owl:Class ;
    rdfs:subClassOf cmpo:CMPParameter ;
    rdfs:label "Material Removal Rate"@en ;
    skos:altLabel "MRR"@en ;
    skos:altLabel "Removal Rate"@en ;
    rdfs:comment "Rate of material removal during CMP, measured in nanometers per minute. A derived parameter computed from pre- and post-polish thickness measurements; the primary output metric of the PHM 2016 dataset."@en .

cmpo:AverageRemovalRate a owl:Class ;
    rdfs:subClassOf cmpo:MaterialRemovalRate ;
    rdfs:label "Average Removal Rate"@en ;
    skos:altLabel "AVG_REMOVAL_RATE"@en ;
    rdfs:comment "Average material removal rate over a complete polishing run of one wafer, in nm/min. The target (label) variable of the PHM 2016 Data Challenge."@en .

### 2.7 Temperature and environmental parameters

cmpo:Temperature a owl:Class ;
    rdfs:subClassOf cmpo:CMPParameter ;
    rdfs:label "Temperature"@en ;
    rdfs:comment "Temperature parameters measured during CMP, in degrees Celsius."@en .

cmpo:PadTemperature a owl:Class ;
    rdfs:subClassOf cmpo:Temperature ;
    rdfs:label "Pad Temperature"@en ;
    rdfs:comment "Temperature of the polishing pad surface, in degrees Celsius. Rises with friction and affects removal rate."@en .

cmpo:EnvironmentalParameter a owl:Class ;
    rdfs:subClassOf cmpo:CMPParameter ;
    rdfs:label "Environmental Parameter"@en ;
    skos:altLabel "Cleanroom Parameter"@en ;
    rdfs:comment "Ambient cleanroom conditions recorded at processing time; they affect slurry chemistry stability, pad properties and process repeatability."@en .

cmpo:CleanroomTemperature a owl:Class ;
    rdfs:subClassOf cmpo:EnvironmentalParameter ;
    rdfs:label "Cleanroom Temperature"@en ;
    rdfs:comment "Ambient air temperature inside the cleanroom, in degrees Celsius. Typical target: 22 ± 0.5 °C."@en .

cmpo:CleanroomHumidity a owl:Class ;
    rdfs:subClassOf cmpo:EnvironmentalParameter ;
    rdfs:label "Cleanroom Humidity"@en ;
    rdfs:comment "Relative humidity of the cleanroom environment (%). Typical target: 45 ± 5 %."@en .

### 2.8 Slurry chemistry parameters

cmpo:SlurryChemistryParameter a owl:Class ;
    rdfs:subClassOf cmpo:CMPParameter ;
    rdfs:label "Slurry Chemistry Parameter"@en ;
    rdfs:comment "Measurable chemical and colloidal properties of the CMP slurry."@en .

cmpo:SlurryPH a owl:Class ;
    rdfs:subClassOf cmpo:SlurryChemistryParameter ;
    rdfs:label "Slurry pH"@en ;
    rdfs:comment "pH value of the slurry on the 0–14 scale; controls surface reaction rates and colloidal stability."@en .

cmpo:SlurryViscosity a owl:Class ;
    rdfs:subClassOf cmpo:SlurryChemistryParameter ;
    rdfs:label "Slurry Viscosity"@en ;
    rdfs:comment "Dynamic viscosity of the slurry, typically in centiPoise (cP) or mPa·s."@en .

cmpo:AbrasiveParticleSize a owl:Class ;
    rdfs:subClassOf cmpo:SlurryChemistryParameter ;
    rdfs:label "Abrasive Particle Size"@en ;
    rdfs:comment "Average size of abrasive particles in the slurry, in nanometers."@en .

cmpo:SolidContent a owl:Class ;
    rdfs:subClassOf cmpo:SlurryChemistryParameter ;
    rdfs:label "Solid Content"@en ;
    rdfs:comment "Percentage of solid abrasive particles in the slurry by weight or volume."@en .

cmpo:ParticleConcentration a owl:Class ;
    rdfs:subClassOf cmpo:SlurryChemistryParameter ;
    rdfs:label "Particle Concentration"@en ;
    rdfs:comment "Number of abrasive particles per unit volume of slurry (particles/mL)."@en .

cmpo:IonicStrength a owl:Class ;
    rdfs:subClassOf cmpo:SlurryChemistryParameter ;
    rdfs:label "Ionic Strength"@en ;
    rdfs:comment "Ionic strength of the slurry solution, in mol/L or mM; affects particle agglomeration."@en .

cmpo:ZetaPotential a owl:Class ;
    rdfs:subClassOf cmpo:SlurryChemistryParameter ;
    rdfs:label "Zeta Potential"@en ;
    rdfs:comment "Electrokinetic potential (mV) of abrasive particles. Values more negative than −30 mV indicate stable dispersion; values near zero indicate agglomeration and scratch risk."@en .

### 2.9 Wafer quality parameters

cmpo:WaferQualityParameter a owl:Class ;
    rdfs:subClassOf cmpo:CMPParameter ;
    rdfs:label "Wafer Quality Parameter"@en ;
    rdfs:comment "Measured quality indicators of a wafer surface, such as thickness, roughness and uniformity metrics."@en .

cmpo:FilmThickness a owl:Class ;
    rdfs:subClassOf cmpo:WaferQualityParameter ;
    rdfs:label "Film Thickness"@en ;
    rdfs:comment "Thickness of the film or layer on the wafer surface, in nanometers; measured pre- and post-CMP to derive removal amounts."@en .

cmpo:SurfaceRoughness a owl:Class ;
    rdfs:subClassOf cmpo:WaferQualityParameter ;
    rdfs:label "Surface Roughness"@en ;
    rdfs:comment "Roughness of the wafer surface (e.g. Ra, Rq), typically measured by AFM after CMP."@en .

cmpo:WithinWaferNonUniformity a owl:Class ;
    rdfs:subClassOf cmpo:WaferQualityParameter ;
    rdfs:label "Within-Wafer Non-Uniformity"@en ;
    skos:altLabel "WIWNU"@en ;
    rdfs:comment "Within-Wafer Non-Uniformity: percentage range or standard deviation of post-CMP film thickness measured at multiple sites across one wafer. Computed as (max − min) / (2 × mean) × 100 or 1-sigma/mean × 100. A key CMP quality KPI."@en .

cmpo:WaferToWaferUniformity a owl:Class ;
    rdfs:subClassOf cmpo:WaferQualityParameter ;
    rdfs:label "Wafer-to-Wafer Uniformity"@en ;
    skos:altLabel "WTWU"@en ;
    rdfs:comment "Wafer-to-Wafer Uniformity: variation of mean removal rate or post-CMP thickness across the wafers of a lot. High values indicate process drift, slurry ageing or pad wear."@en .

#################################################################
### 3. FEATURES OF INTEREST (what is measured on)
#################################################################

cmpo:Wafer a owl:Class ;
    rdfs:subClassOf sosa:FeatureOfInterest ;
    rdfs:label "Wafer"@en ;
    rdfs:comment "A silicon substrate used for manufacturing semiconductor devices; the primary feature of interest of CMP observations."@en .

cmpo:DummyWafer a owl:Class ;
    rdfs:subClassOf cmpo:Wafer ;
    rdfs:label "Dummy Wafer"@en ;
    rdfs:comment "Pure silicon wafer without device layers, used to break in tools before actual use or to check tool functionality after an equipment change."@en .

cmpo:ControlWafer a owl:Class ;
    rdfs:subClassOf cmpo:Wafer ;
    rdfs:label "Control Wafer"@en , "Kontrollwafer"@de ;
    skos:altLabel "K-Scheibe"@de ;
    rdfs:comment "Unstructured wafer in a wafer lot used to measure properties such as uniformity and roughness before polishing; used to calculate the material removal rate."@en .

cmpo:StructuredWafer a owl:Class ;
    rdfs:subClassOf cmpo:Wafer ;
    rdfs:label "Structured Wafer"@en ;
    rdfs:comment "Wafer with a device layout for actual production; may not be measurable by non-destructive optical methods."@en .

cmpo:Layer a owl:Class ;
    rdfs:label "Layer"@en ;
    rdfs:comment "A specific material layer on a wafer. Structured wafers can have multiple layers; dummy wafers have none."@en .

cmpo:Material a owl:Class ;
    rdfs:label "Material"@en ;
    rdfs:comment "A material such as silicon, copper, tungsten or silicon dioxide, used as substrate, layer or abrasive material."@en .

cmpo:Lot a owl:Class ;
    rdfs:subClassOf sosa:FeatureOfInterest ;
    rdfs:label "Wafer Lot"@en ;
    rdfs:comment "A batch of wafers processed together, identified by a lot number; lot-level parameters such as wafer-to-wafer uniformity are observed on it."@en .

cmpo:LotType a owl:Class ;
    rdfs:label "Lot Type"@en ;
    rdfs:comment "Classification of a wafer lot by purpose in the production flow; determines handling rules, measurement frequency and disposition criteria."@en .

cmpo:ProductionLot a owl:Class ;
    rdfs:subClassOf cmpo:LotType ;
    rdfs:label "Production Lot"@en ;
    rdfs:comment "Regular production lot containing customer product wafers, processed with the released production recipe."@en .

cmpo:EngineeringLot a owl:Class ;
    rdfs:subClassOf cmpo:LotType ;
    rdfs:label "Engineering Lot"@en ;
    rdfs:comment "Lot used for process development, recipe optimisation, DOE experiments or failure analysis; not shipped to customers."@en .

cmpo:QualificationLot a owl:Class ;
    rdfs:subClassOf cmpo:LotType ;
    rdfs:label "Qualification Lot"@en ;
    rdfs:comment "Lot processed to validate a new recipe, tool configuration or consumable change before release to production."@en .

cmpo:Project a owl:Class ;
    rdfs:label "Project"@en ;
    rdfs:comment "The project a wafer or lot belongs to. For dummy wafers the project is called Dummy; otherwise it is a project name or number (e.g. XENA)."@en .

cmpo:WaferState a owl:Class ;
    rdfs:subClassOf sosa:FeatureOfInterest ;
    rdfs:label "Wafer State"@en ;
    rdfs:comment "The physical state of a wafer at a point in time (e.g. after a polishing step), carrying state-dependent facts such as detected defects and actual removal amounts."@en .

cmpo:WaferStatus a owl:Class ;
    rdfs:label "Wafer Status"@en ;
    rdfs:comment "Normative processing status of a wafer. Process-card encoding: x = to be done; 0 = not done; 1 = finished; 2 = tool error; 3 = wafer out of spec; 4 = wafer crashed."@en .

cmpo:CrystallographicOrientation a owl:Class ;
    rdfs:label "Crystallographic Orientation"@en ;
    rdfs:comment "Orientation of the wafer crystal lattice relative to the wafer flat or notch; affects polishing behavior."@en .

cmpo:WaferNotch a owl:Class ;
    rdfs:label "Wafer Notch"@en ;
    rdfs:comment "Mechanical alignment feature on the wafer edge used for angular orientation in the carrier and on metrology stages."@en .

cmpo:VNotch a owl:Class ;
    rdfs:subClassOf cmpo:WaferNotch ;
    rdfs:label "V-Notch"@en ;
    rdfs:comment "V-shaped notch on the wafer edge; SEMI standard for 200 mm and 300 mm wafers."@en .

cmpo:PrimaryFlat a owl:Class ;
    rdfs:subClassOf cmpo:WaferNotch ;
    rdfs:label "Primary Flat"@en ;
    rdfs:comment "Flat section ground on the wafer edge indicating crystallographic orientation; standard for 100 mm and 150 mm wafers. Causes edge non-uniformity near its location."@en .

#################################################################
### 4. PLATFORMS: TOOLS AND TOOL COMPONENTS (what measures / processes)
#################################################################

cmpo:Equipment a owl:Class ;
    rdfs:subClassOf sosa:Platform ;
    rdfs:label "Equipment"@en ;
    rdfs:comment "Any piece of fab equipment. Root class of tools and their components."@en .

cmpo:Tool a owl:Class ;
    rdfs:subClassOf cmpo:Equipment ;
    rdfs:label "Tool"@en ;
    skos:altLabel "Machine"@en ;
    rdfs:comment "A machine for processing or measuring wafers (e.g. a CMP polisher or a metrology tool). Specific tools are instances; PHM 2016 machines map to instances of this class."@en .

cmpo:ToolComponent a owl:Class ;
    rdfs:subClassOf cmpo:Equipment ;
    rdfs:label "Tool Component"@en ;
    rdfs:comment "A physical part of a tool, such as a platen, carrier, conditioner or chamber. Components host sensors and are the platforms on which observations are made."@en .

cmpo:CMPToolType a owl:Class ;
    rdfs:label "CMP Tool Type"@en ;
    rdfs:comment "Kinematic configuration of a CMP tool; determines how relative motion between wafer and pad is generated."@en .

cmpo:RotaryCMPTool a owl:Class ;
    rdfs:subClassOf cmpo:CMPToolType ;
    rdfs:label "Rotary CMP Tool"@en ;
    rdfs:comment "Most common configuration: platen and carrier head rotate independently (e.g. AMAT Mirra, Reflexion LK)."@en .

cmpo:LinearCMPTool a owl:Class ;
    rdfs:subClassOf cmpo:CMPToolType ;
    rdfs:label "Linear CMP Tool"@en ;
    rdfs:comment "Configuration using a linearly moving endless belt as the polishing pad, giving constant relative velocity across the wafer."@en .

cmpo:OrbitalCMPTool a owl:Class ;
    rdfs:subClassOf cmpo:CMPToolType ;
    rdfs:label "Orbital CMP Tool"@en ;
    rdfs:comment "Configuration where the carrier head moves in an orbital pattern while the platen rotates (e.g. EBARA EPO series)."@en .

cmpo:Platen a owl:Class ;
    rdfs:subClassOf cmpo:ToolComponent ;
    rdfs:label "Platen"@en ;
    skos:altLabel "Polishing Stage"@en ;
    skos:altLabel "Stage"@en ;
    skos:altLabel "Polishing Table"@en ;
    rdfs:comment "The large rotating disk on which the polishing pad is mounted. Appears as Stage in the PHM 2016 dataset."@en .

cmpo:Carrier a owl:Class ;
    rdfs:subClassOf cmpo:ToolComponent ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty cmpo:hasPressureZone ; owl:minCardinality "1"^^xsd:nonNegativeInteger ] ;
    rdfs:label "Carrier"@en ;
    skos:altLabel "Head"@en ;
    skos:altLabel "Wafer Head"@en ;
    skos:altLabel "Polishing Head"@en ;
    rdfs:comment "The component that holds the wafer during polishing. At least one pressure zone is required for functional operation."@en .

cmpo:PressureZone a owl:Class ;
    rdfs:subClassOf cmpo:ToolComponent ;
    rdfs:label "Pressure Zone"@en ;
    rdfs:comment "A region in a carrier that can be independently pressurized. The number and configuration vary by tool. The pressure of a zone is observed via the corresponding cmpo:Pressure observable property."@en .

cmpo:RetainingRingZone a owl:Class ;
    rdfs:subClassOf cmpo:PressureZone ;
    rdfs:label "Retaining Ring Zone"@en ;
    rdfs:comment "Pressure zone of the retaining ring; its pressure signal is cmpo:RetainingRingPressure."@en .

cmpo:MembraneZone a owl:Class ;
    rdfs:subClassOf cmpo:PressureZone ;
    rdfs:label "Membrane Zone"@en ;
    rdfs:comment "Pressure zone formed by the carrier membrane."@en .

cmpo:CenterAirBagZone a owl:Class ;
    rdfs:subClassOf cmpo:PressureZone ;
    rdfs:label "Center Air Bag Zone"@en ;
    rdfs:comment "Central air-bag pressure zone of the carrier; its pressure signal is cmpo:CenterAirBagPressure."@en .

cmpo:MainOuterAirBagZone a owl:Class ;
    rdfs:subClassOf cmpo:PressureZone ;
    rdfs:label "Main Outer Air Bag Zone"@en ;
    rdfs:comment "Main outer air-bag pressure zone of the carrier; its pressure signal is cmpo:MainOuterAirBagPressure."@en .

cmpo:RippleAirBagZone a owl:Class ;
    rdfs:subClassOf cmpo:PressureZone ;
    rdfs:label "Ripple Air Bag Zone"@en ;
    rdfs:comment "Ripple air-bag pressure zone of the carrier; its pressure signal is cmpo:RippleAirBagPressure."@en .

cmpo:EdgeAirBagZone a owl:Class ;
    rdfs:subClassOf cmpo:PressureZone ;
    rdfs:label "Edge Air Bag Zone"@en ;
    rdfs:comment "Edge air-bag pressure zone of the carrier; its pressure signal is cmpo:EdgeAirBagPressure."@en .

cmpo:Chamber a owl:Class ;
    rdfs:subClassOf cmpo:ToolComponent ;
    rdfs:label "Chamber"@en ;
    rdfs:comment "A processing chamber of a tool, identified by a chamber number. Not to be confused with the pressure zones inside the carrier."@en .

cmpo:Conditioner a owl:Class ;
    rdfs:subClassOf cmpo:ToolComponent ;
    rdfs:label "Conditioner"@en ;
    skos:altLabel "Dresser"@en ;
    skos:altLabel "Pad Conditioner"@en ;
    rdfs:comment "The arm-mounted component that regenerates the polishing pad surface during or between polishing runs; measured and configured in sweeps per minute."@en .

cmpo:ConditionerTable a owl:Class ;
    rdfs:subClassOf cmpo:ToolComponent ;
    rdfs:label "Conditioner Table"@en ;
    skos:altLabel "Dresser Table"@en ;
    rdfs:comment "The parking position of the conditioner, where it is rinsed and cleaned with deionized water."@en .

cmpo:SlurryPipe a owl:Class ;
    rdfs:subClassOf cmpo:ToolComponent ;
    rdfs:label "Slurry Pipe"@en ;
    skos:altLabel "Slurry Line"@en ;
    skos:altLabel "Slurry Delivery Pipe"@en ;
    rdfs:comment "Delivery line for slurry or DI water; the PHM 2016 slurry flow signals (lines A, B, C) are measured on these pipes."@en .

cmpo:MetrologyTool a owl:Class ;
    rdfs:subClassOf cmpo:Tool ;
    rdfs:label "Metrology Tool"@en ;
    rdfs:comment "A tool used exclusively for measurement and characterisation of wafer properties; performs no material removal (e.g. FTR, AFM, ellipsometer, profilometer)."@en .

cmpo:FTRTool a owl:Class ;
    rdfs:subClassOf cmpo:MetrologyTool ;
    rdfs:label "FTR Tool"@en ;
    rdfs:comment "Film Thickness and Reflectance tool; uses optical interferometry or reflectometry to measure thin-film thickness and within-wafer uniformity."@en .

cmpo:EllipsometerTool a owl:Class ;
    rdfs:subClassOf cmpo:MetrologyTool ;
    rdfs:label "Ellipsometer"@en ;
    rdfs:comment "Optical metrology tool measuring film thickness and optical constants from the polarisation state of reflected light."@en .

cmpo:AFMTool a owl:Class ;
    rdfs:subClassOf cmpo:MetrologyTool ;
    rdfs:label "AFM Tool"@en ;
    rdfs:comment "Atomic Force Microscopy tool; measures surface roughness at nanometre resolution to characterise post-CMP surface quality."@en .

cmpo:ProfilometerTool a owl:Class ;
    rdfs:subClassOf cmpo:MetrologyTool ;
    rdfs:label "Profilometer"@en ;
    rdfs:comment "Contact or optical surface profiler; measures step heights, dishing and erosion after CMP."@en .

cmpo:SEMTool a owl:Class ;
    rdfs:subClassOf cmpo:MetrologyTool ;
    rdfs:label "SEM Tool"@en ;
    rdfs:comment "Scanning Electron Microscopy tool; high-resolution imaging for scratch detection and contamination analysis after CMP."@en .

#################################################################
### 5. CONSUMABLES
#################################################################

cmpo:Consumable a owl:Class ;
    rdfs:subClassOf cmpo:ToolComponent ;
    rdfs:label "Consumable"@en ;
    rdfs:comment "A tool component that wears out over time and has a defined lifetime or service life (pads, rings, membranes, slurry, discs)."@en .

cmpo:PolishingPad a owl:Class ;
    rdfs:subClassOf cmpo:Consumable ;
    rdfs:label "Polishing Pad"@en ;
    rdfs:comment "The consumable pad mounted on the platen against which the wafer is polished; its type, hardness and groove pattern govern removal rate and defectivity."@en .

cmpo:ConditionerPad a owl:Class ;
    rdfs:subClassOf cmpo:Consumable ;
    rdfs:label "Conditioner Pad"@en ;
    rdfs:comment "Consumable pad of the conditioner assembly."@en .

cmpo:ConditionerDisc a owl:Class ;
    rdfs:subClassOf cmpo:Consumable ;
    rdfs:label "Conditioner Disc"@en ;
    rdfs:comment "Diamond-embedded disc mounted on the conditioner arm; regenerates the micro-texture (asperities) of the polishing pad by abrasive dressing."@en .

cmpo:RetainingRing a owl:Class ;
    rdfs:subClassOf cmpo:Consumable ;
    rdfs:label "Retaining Ring"@en ;
    skos:altLabel "Retainer Ring"@en ;
    rdfs:comment "Consumable ring around the wafer in the carrier that keeps the wafer in place during polishing."@en .

cmpo:Membrane a owl:Class ;
    rdfs:subClassOf cmpo:Consumable ;
    rdfs:label "Membrane"@en ;
    rdfs:comment "Flexible carrier membrane that transmits zone pressures onto the wafer backside."@en .

cmpo:PressurizedSheet a owl:Class ;
    rdfs:subClassOf cmpo:Consumable ;
    rdfs:label "Pressurized Sheet"@en ;
    rdfs:comment "Consumable pressurized sheet in the carrier assembly."@en .

cmpo:BackingFilm a owl:Class ;
    rdfs:subClassOf cmpo:Consumable ;
    rdfs:label "Backing Film"@en ;
    rdfs:comment "Consumable film between carrier and wafer backside that cushions the wafer."@en .

cmpo:Slurry a owl:Class ;
    rdfs:subClassOf cmpo:Consumable ;
    rdfs:label "Slurry"@en ;
    rdfs:comment "Chemical-mechanical polishing suspension of abrasive particles and reactive chemicals delivered onto the pad."@en .

cmpo:DiWater a owl:Class ;
    rdfs:subClassOf cmpo:Consumable ;
    rdfs:label "DI Water"@en ;
    rdfs:comment "Deionized water used for rinsing and cleaning; delivered through slurry pipes depending on the step."@en .

cmpo:CleaningAgent a owl:Class ;
    rdfs:subClassOf cmpo:Consumable ;
    rdfs:label "Cleaning Agent"@en ;
    rdfs:comment "Chemical used in the post-CMP cleaning process to remove residual slurry and contaminants."@en .

cmpo:SlurryChemistry a owl:Class ;
    rdfs:label "Slurry Chemistry"@en ;
    rdfs:comment "The chemical composition and colloidal properties of a CMP slurry formulation."@en .

cmpo:AbrasiveType a owl:Class ;
    rdfs:label "Abrasive Type"@en ;
    rdfs:comment "Material class of the abrasive particles suspended in the slurry; determines hardness, reactivity and selectivity."@en .

cmpo:SilicaAbrasive a owl:Class ;
    rdfs:subClassOf cmpo:AbrasiveType ;
    rdfs:label "Silica Abrasive"@en ;
    rdfs:comment "Silicon dioxide abrasive particles; most widely used, applied in oxide, STI and polysilicon CMP (Mohs ~7)."@en .

cmpo:AluminaAbrasive a owl:Class ;
    rdfs:subClassOf cmpo:AbrasiveType ;
    rdfs:label "Alumina Abrasive"@en ;
    rdfs:comment "Aluminium oxide abrasive particles; used in tungsten and metal CMP due to higher hardness (Mohs ~9)."@en .

cmpo:CeriaAbrasive a owl:Class ;
    rdfs:subClassOf cmpo:AbrasiveType ;
    rdfs:label "Ceria Abrasive"@en ;
    rdfs:comment "Cerium oxide abrasive particles; used in STI and oxide CMP for high SiO2/Si3N4 selectivity."@en .

cmpo:ChemicalAdditive a owl:Class ;
    rdfs:label "Chemical Additive"@en ;
    rdfs:comment "Chemical compound added to the slurry to modify removal rate, selectivity, surface protection or colloidal stability."@en .

cmpo:Oxidizer a owl:Class ;
    rdfs:subClassOf cmpo:ChemicalAdditive ;
    rdfs:label "Oxidizer"@en ;
    rdfs:comment "Oxidising agent that forms a passivation layer on the metal surface enabling mechanical removal (e.g. H2O2 in Cu CMP)."@en .

cmpo:Inhibitor a owl:Class ;
    rdfs:subClassOf cmpo:ChemicalAdditive ;
    rdfs:label "Corrosion Inhibitor"@en ;
    rdfs:comment "Chemical forming a self-limiting protective layer on metal surfaces to prevent over-corrosion in recessed areas (e.g. BTA in Cu CMP); key to minimising dishing."@en .

cmpo:Complexant a owl:Class ;
    rdfs:subClassOf cmpo:ChemicalAdditive ;
    rdfs:label "Complexing Agent"@en ;
    rdfs:comment "Chemical forming soluble metal complexes to facilitate removal of oxidised metal ions (e.g. citric acid, glycine in Cu CMP)."@en .

cmpo:Surfactant a owl:Class ;
    rdfs:subClassOf cmpo:ChemicalAdditive ;
    rdfs:label "Surfactant"@en ;
    rdfs:comment "Surface-active agent improving wettability, reducing abrasive agglomeration and minimising scratch defectivity."@en .

cmpo:GroovePattern a owl:Class ;
    rdfs:label "Groove Pattern"@en ;
    rdfs:comment "Geometric groove configuration on the polishing pad surface; governs slurry transport, fresh abrasive delivery and contact mechanics."@en .

cmpo:ConcentricGroove a owl:Class ;
    rdfs:subClassOf cmpo:GroovePattern ;
    rdfs:label "Concentric Groove"@en ;
    rdfs:comment "Concentric circular grooves (common on IC1000 pads); balances slurry retention and transport."@en .

cmpo:XYGroove a owl:Class ;
    rdfs:subClassOf cmpo:GroovePattern ;
    rdfs:label "XY Groove"@en ;
    rdfs:comment "Orthogonal grid groove pattern; uniform slurry distribution in both directions."@en .

cmpo:SpiralGroove a owl:Class ;
    rdfs:subClassOf cmpo:GroovePattern ;
    rdfs:label "Spiral Groove"@en ;
    rdfs:comment "Spiral groove pattern; promotes centrifugal slurry transport outward from the pad centre."@en .

cmpo:PerforatedPad a owl:Class ;
    rdfs:subClassOf cmpo:GroovePattern ;
    rdfs:label "Perforated Pad"@en ;
    rdfs:comment "Pad with through-holes enabling in-situ optical end-point detection via a pad window."@en .

#################################################################
### 6. PROCESS: SERVICES, STEPS, RECIPES, MODES
#################################################################

cmpo:Service a owl:Class ;
    rdfs:label "Service"@en ;
    rdfs:comment "A general production-process stage or operator group in chip production, such as CMP, PVD or ALD, as labelled on the process card."@en .

cmpo:PolishingStep a owl:Class ;
    rdfs:label "Polishing Step"@en ;
    skos:altLabel "Step"@en ;
    skos:altLabel "Task"@en ;
    rdfs:comment "One action in the process workflow, e.g. a polishing run on a CMP tool or a measuring step on an FTR tool. PHM 2016 stages (A/B) map to steps executed on specific platens."@en .

cmpo:Recipe a owl:Class ;
    rdfs:subClassOf sosa:Procedure ;
    rdfs:label "Recipe"@en ;
    rdfs:comment "A collection of set-point instructions (target pressures, speeds, sweep rates) governing how a polishing step is executed. Modeled as a SOSA procedure."@en .

cmpo:SetPoint a owl:Class ;
    rdfs:label "Set Point"@en ;
    rdfs:comment "A single target instruction within a recipe: the intended value of one observable parameter (e.g. retaining ring pressure = 5.0 psi). Distinct from observations, which record what actually happened."@en .

cmpo:PolishingMode a owl:Class ;
    rdfs:label "Polishing Mode"@en ;
    rdfs:comment "Functional phase of a polishing step within the planarisation sequence; determines target removal rate, pad type and slurry formulation."@en .

cmpo:BulkRemoval a owl:Class ;
    rdfs:subClassOf cmpo:PolishingMode ;
    rdfs:label "Bulk Removal"@en ;
    rdfs:comment "First polishing phase; rapidly removes the bulk of excess material at a high removal rate on a stiff pad with abrasive-rich slurry."@en .

cmpo:FinePolishing a owl:Class ;
    rdfs:subClassOf cmpo:PolishingMode ;
    rdfs:label "Fine Polishing"@en ;
    rdfs:comment "Second polishing phase targeting final thickness and improved surface quality at a lower removal rate."@en .

cmpo:Buffing a owl:Class ;
    rdfs:subClassOf cmpo:PolishingMode ;
    rdfs:label "Buffing"@en ;
    rdfs:comment "Light final polishing step improving surface roughness and removing slurry residue, often on a soft pad."@en .

cmpo:Clearing a owl:Class ;
    rdfs:subClassOf cmpo:PolishingMode ;
    rdfs:label "Clearing"@en ;
    rdfs:comment "Phase removing residual barrier (e.g. Ta, TaN) or seed layer from field regions after bulk metal removal."@en .

cmpo:PostCMPCleaning a owl:Class ;
    rdfs:label "Post-CMP Cleaning"@en ;
    rdfs:comment "Cleaning step performed after polishing to remove residual slurry and contaminants from the wafer."@en .

cmpo:EndPointDetection a owl:Class ;
    rdfs:label "End-Point Detection"@en ;
    rdfs:comment "Methods and mechanisms used to determine when CMP polishing of a layer is complete."@en .

cmpo:EPDMethod a owl:Class ;
    rdfs:subClassOf cmpo:EndPointDetection ;
    rdfs:label "EPD Method"@en ;
    rdfs:comment "A specific technique or sensor used for end-point detection."@en .

cmpo:OpticalEPD a owl:Class ;
    rdfs:subClassOf cmpo:EPDMethod ;
    rdfs:label "Optical EPD"@en ;
    rdfs:comment "Optical spectrometry-based end-point detection through a pad window."@en .

cmpo:ImpedanceEPD a owl:Class ;
    rdfs:subClassOf cmpo:EPDMethod ;
    rdfs:label "Impedance EPD"@en ;
    rdfs:comment "Electrical impedance-based end-point detection."@en .

cmpo:MotorCurrentEPD a owl:Class ;
    rdfs:subClassOf cmpo:EPDMethod ;
    rdfs:label "Motor Current EPD"@en ;
    rdfs:comment "End-point detection based on motor current signature analysis; friction changes when a new material layer is reached."@en .

cmpo:MotionProfile a owl:Class ;
    rdfs:label "Motion Profile"@en ;
    rdfs:comment "Pattern of motion applied by the carrier to the wafer during polishing."@en .

cmpo:OrbitalMotion a owl:Class ;
    rdfs:subClassOf cmpo:MotionProfile ;
    rdfs:label "Orbital Motion"@en ;
    rdfs:comment "Carrier moves the wafer in a circular/orbital pattern on the pad."@en .

cmpo:LinearMotion a owl:Class ;
    rdfs:subClassOf cmpo:MotionProfile ;
    rdfs:label "Linear Motion"@en ;
    rdfs:comment "Carrier moves the wafer in a linear back-and-forth pattern."@en .

cmpo:WaferSide a owl:Class ;
    rdfs:label "Wafer Side"@en ;
    rdfs:comment "Side of the wafer targeted by a processing step (front side or back side)."@en .

cmpo:FrontSide a owl:Class ;
    rdfs:subClassOf cmpo:WaferSide ;
    rdfs:label "Front Side"@en ;
    rdfs:comment "The device-bearing front side of the wafer."@en .

cmpo:BackSide a owl:Class ;
    rdfs:subClassOf cmpo:WaferSide ;
    rdfs:label "Back Side"@en ;
    rdfs:comment "The back side of the wafer."@en .

#################################################################
### 7. QUALITY, CONTROL AND PROCESS MODELS
#################################################################

cmpo:ProcessCard a owl:Class ;
    rdfs:label "Process Card"@en ;
    rdfs:comment "A document connected to a wafer lot containing information about all wafers in the lot, including defects, notes, target values and planned services."@en .

cmpo:ProcessWindow a owl:Class ;
    rdfs:label "Process Window"@en ;
    rdfs:comment "The range of acceptable values of a process parameter within which the CMP process reliably yields conforming wafers; derived from design-of-experiment studies."@en .

cmpo:SPCLimit a owl:Class ;
    rdfs:label "SPC Limit"@en ;
    rdfs:comment "Statistical Process Control limits for a monitored parameter: control limits (±3σ, trigger investigation) and specification limits (engineering tolerance)."@en .

cmpo:RunToRunControl a owl:Class ;
    rdfs:label "Run-to-Run Control"@en ;
    rdfs:comment "Advanced Process Control strategy that adjusts recipe set-points between wafer runs based on measured output feedback, compensating pad wear, slurry ageing and tool drift."@en .

cmpo:PrestonModel a owl:Class ;
    rdfs:label "Preston Model"@en ;
    skos:altLabel "Preston Equation"@en ;
    rdfs:comment "Fundamental CMP model MRR = k_p × P × V, where k_p is the Preston coefficient, P the contact pressure and V the relative velocity; captures the combined mechanical and chemical removal mechanism."@en .

cmpo:MaterialSelectivity a owl:Class ;
    rdfs:label "Material Selectivity"@en ;
    rdfs:comment "Ratio of the removal rate of a primary material to a reference material under identical CMP conditions; key for stop-on-layer and barrier CMP steps."@en .

cmpo:ToolQualification a owl:Class ;
    rdfs:label "Tool Qualification"@en ;
    rdfs:comment "Process of preparing and qualifying a CMP tool for production use after installation, maintenance or consumable change."@en .

cmpo:UsageTracking a owl:Class ;
    rdfs:label "Usage Tracking"@en ;
    owl:hasKey (cmpo:usageId) ;
    rdfs:comment "A record tracking the usage metrics (runtime, count, wear) of a consumable or tool component."@en .

#################################################################
### 8. DEFECTS
#################################################################

cmpo:DefectType a owl:Class ;
    rdfs:label "Defect Type"@en ;
    rdfs:comment "Classification of defects that can occur on a wafer during processing."@en .

cmpo:CMPDefect a owl:Class ;
    rdfs:subClassOf cmpo:DefectType ;
    rdfs:label "CMP Defect"@en ;
    rdfs:comment "Defects originating from the CMP polishing process."@en .

cmpo:Scratch a owl:Class ;
    rdfs:subClassOf cmpo:CMPDefect ;
    rdfs:label "Scratch"@en ;
    rdfs:comment "Fine linear scratches caused by abrasive particles or pad irregularities."@en .

cmpo:Dishing a owl:Class ;
    rdfs:subClassOf cmpo:CMPDefect ;
    rdfs:label "Dishing"@en ;
    rdfs:comment "Localized depression of the polished surface below the intended level, typically over soft metal lines."@en .

cmpo:Erosion a owl:Class ;
    rdfs:subClassOf cmpo:CMPDefect ;
    rdfs:label "Erosion"@en ;
    rdfs:comment "Non-uniform removal of material creating recessed regions, typically thinning of dielectric in dense pattern areas."@en .

cmpo:Corrosion a owl:Class ;
    rdfs:subClassOf cmpo:CMPDefect ;
    rdfs:label "Corrosion"@en ;
    rdfs:comment "Chemical degradation of the wafer surface during polishing."@en .

cmpo:Overpolish a owl:Class ;
    rdfs:subClassOf cmpo:CMPDefect ;
    rdfs:label "Overpolish"@en ;
    rdfs:comment "Excessive material removal beyond the intended stop layer."@en .

cmpo:Underpolish a owl:Class ;
    rdfs:subClassOf cmpo:CMPDefect ;
    rdfs:label "Underpolish"@en ;
    rdfs:comment "Insufficient material removal leaving residual material on the surface."@en .

#################################################################
### 9. AGENTS AND ROLES
#################################################################

cmpo:Agent a owl:Class ;
    rdfs:label "Agent"@en ;
    rdfs:comment "A person or organizational actor involved in the CMP process, carrying one or more roles."@en .

cmpo:Role a owl:Class ;
    rdfs:label "Role"@en ;
    rdfs:comment "A responsibility an agent can carry in the process, such as project owner or process owner."@en .

cmpo:ProjectOwner a owl:Class ;
    rdfs:subClassOf cmpo:Role ;
    rdfs:label "Project Owner"@en , "Projektverantwortlicher"@de ;
    skos:altLabel "Lot Owner"@en ;
    rdfs:comment "The person responsible for a wafer lot; acts as the internal customer of the process and defines target values."@en .

cmpo:ProcessOwner a owl:Class ;
    rdfs:subClassOf cmpo:Role ;
    rdfs:label "Process Owner"@en , "Prozessverantwortlicher"@de ;
    skos:altLabel "Tool Expert"@en ;
    skos:altLabel "Operator"@en ;
    rdfs:comment "The person responsible for a specific process or tool."@en .

#################################################################
### 10. UNITS (QUDT-aligned)
#################################################################

cmpo:Unit a owl:Class ;
    rdfs:subClassOf qudt:Unit ;
    rdfs:label "Unit"@en ;
    rdfs:comment "Domain-specific measurement unit, aligned with QUDT unit individuals via owl:sameAs."@en .

cmpo:Angstrom a cmpo:Unit ; owl:sameAs unit:ANGSTROM ; qudt:hasSymbol "Å" ;
    rdfs:label "Angstrom"@en ; rdfs:comment "Length unit used for very thin films (0.1 nm)."@en .
cmpo:Nanometer a cmpo:Unit ; owl:sameAs unit:NanoM ; qudt:hasSymbol "nm" ;
    rdfs:label "Nanometer"@en ; rdfs:comment "Length unit used for film thickness and removal amounts."@en .
cmpo:Micrometer a cmpo:Unit ; owl:sameAs unit:MicroM ; qudt:hasSymbol "µm" ;
    rdfs:label "Micrometer"@en ; rdfs:comment "Length unit used for defect dimensions and pad grooves."@en .
cmpo:Millimeter a cmpo:Unit ; owl:sameAs unit:MilliM ; qudt:hasSymbol "mm" ;
    rdfs:label "Millimeter"@en ; rdfs:comment "Length unit used for wafer diameter and edge exclusion."@en .
cmpo:PSI a cmpo:Unit ; owl:sameAs unit:PSI ; qudt:hasSymbol "psi" ;
    rdfs:label "Pounds per Square Inch"@en ; rdfs:comment "Pressure unit commonly used for carrier zone pressures."@en .
cmpo:Bar a cmpo:Unit ; owl:sameAs unit:BAR ; qudt:hasSymbol "bar" ;
    rdfs:label "Bar"@en ; rdfs:comment "Pressure unit."@en .
cmpo:Newton a cmpo:Unit ; owl:sameAs unit:N ; qudt:hasSymbol "N" ;
    rdfs:label "Newton"@en ; rdfs:comment "Force unit used for downforce and conditioning force."@en .
cmpo:Second a cmpo:Unit ; owl:sameAs unit:SEC ; qudt:hasSymbol "s" ;
    rdfs:label "Second"@en ; rdfs:comment "Time unit used for durations and dwell times."@en .
cmpo:Minute a cmpo:Unit ; owl:sameAs unit:MIN ; qudt:hasSymbol "min" ;
    rdfs:label "Minute"@en ; rdfs:comment "Time unit used for lifetimes and accumulated usage."@en .
cmpo:RPM a cmpo:Unit ; owl:sameAs unit:REV-PER-MIN ; qudt:hasSymbol "rpm" ;
    rdfs:label "Revolutions per Minute"@en ; rdfs:comment "Rotational speed unit for platen and carrier rotation."@en .
cmpo:MeterPerSecond a cmpo:Unit ; owl:sameAs unit:M-PER-SEC ; qudt:hasSymbol "m/s" ;
    rdfs:label "Meter per Second"@en ; rdfs:comment "Velocity unit for wafer-pad relative velocity."@en .
cmpo:MilliliterPerMinute a cmpo:Unit ; owl:sameAs unit:MilliL-PER-MIN ; qudt:hasSymbol "ml/min" ;
    rdfs:label "Milliliter per Minute"@en ; rdfs:comment "Flow-rate unit for slurry delivery lines."@en .
cmpo:Percent a cmpo:Unit ; owl:sameAs unit:PERCENT ; qudt:hasSymbol "%" ;
    rdfs:label "Percent"@en ; rdfs:comment "Percentage unit for uniformity, solid content and ratios."@en .
cmpo:DegreeCelsius a cmpo:Unit ; owl:sameAs unit:DEG_C ; qudt:hasSymbol "°C" ;
    rdfs:label "Degree Celsius"@en ; rdfs:comment "Temperature unit."@en .
cmpo:NanometerPerMinute a cmpo:Unit ; owl:sameAs unit:NanoM-PER-MIN ; qudt:hasSymbol "nm/min" ;
    rdfs:label "Nanometer per Minute"@en ; rdfs:comment "Removal-rate unit for MRR values."@en .

### Canonical unit assignments
cmpo:Pressure           cmpo:canonicalUnit cmpo:PSI .
cmpo:Downforce          cmpo:canonicalUnit cmpo:Newton .
cmpo:Velocity           cmpo:canonicalUnit cmpo:RPM .
cmpo:RelativeVelocity   cmpo:canonicalUnit cmpo:MeterPerSecond .
cmpo:SlurryFlowRate     cmpo:canonicalUnit cmpo:MilliliterPerMinute .
cmpo:MaterialRemovalRate cmpo:canonicalUnit cmpo:NanometerPerMinute .
cmpo:Temperature        cmpo:canonicalUnit cmpo:DegreeCelsius .
cmpo:CleanroomHumidity  cmpo:canonicalUnit cmpo:Percent .
cmpo:WithinWaferNonUniformity cmpo:canonicalUnit cmpo:Percent .
cmpo:WaferToWaferUniformity   cmpo:canonicalUnit cmpo:Percent .
cmpo:FilmThickness      cmpo:canonicalUnit cmpo:Nanometer .

#################################################################
### 11. OBJECT PROPERTIES
#################################################################

cmpo:hasWaferId a owl:DatatypeProperty , owl:FunctionalProperty ;
    skos:altLabel "WAFER_ID"@en ;
    rdfs:label "has wafer ID"@en ;
    rdfs:domain cmpo:Wafer ;
    rdfs:range xsd:string ;
    rdfs:comment "Unique identifier of a wafer (e.g. 371447024 in the PHM 2016 dataset)."@en .

cmpo:hasIndexValue a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "has index value"@en ;
    rdfs:domain cmpo:Wafer ;
    rdfs:range xsd:integer ;
    rdfs:comment "Position of the wafer within its wafer box, an integer between 1 and 25."@en .

cmpo:isPartOfLot a owl:ObjectProperty ;
    rdfs:label "is part of lot"@en ;
    rdfs:domain cmpo:Wafer ;
    rdfs:range cmpo:Lot ;
    rdfs:comment "Assigns a wafer to the wafer lot it belongs to."@en .

cmpo:hasLotType a owl:ObjectProperty ;
    rdfs:label "has lot type"@en ;
    rdfs:domain cmpo:Lot ;
    rdfs:range cmpo:LotType ;
    rdfs:comment "Classifies a wafer lot by its purpose in the fab production flow."@en .

cmpo:belongsToProject a owl:ObjectProperty ;
    rdfs:label "belongs to project"@en ;
    rdfs:domain cmpo:Lot ;
    rdfs:range cmpo:Project ;
    rdfs:comment "Assigns a lot (and thereby its wafers) to a project."@en .

cmpo:hasLayer a owl:ObjectProperty ;
    rdfs:label "has layer"@en ;
    rdfs:domain cmpo:Wafer ;
    rdfs:range cmpo:Layer ;
    rdfs:comment "Links a wafer to one of its material layers."@en .

cmpo:hasMaterial a owl:ObjectProperty ;
    rdfs:label "has material"@en ;
    rdfs:domain cmpo:Layer ;
    rdfs:range cmpo:Material ;
    rdfs:comment "Specifies the material a layer consists of."@en .

cmpo:hasSubstrate a owl:ObjectProperty ;
    rdfs:label "has substrate"@en ;
    rdfs:domain cmpo:Wafer ;
    rdfs:range cmpo:Material ;
    rdfs:comment "The material the bare wafer is made from, in most cases silicon."@en .

cmpo:hasOrientation a owl:ObjectProperty ;
    rdfs:label "has orientation"@en ;
    rdfs:domain cmpo:Wafer ;
    rdfs:range cmpo:CrystallographicOrientation ;
    rdfs:comment "Specifies the crystallographic orientation of the wafer."@en .

cmpo:hasNotch a owl:ObjectProperty ;
    rdfs:label "has notch"@en ;
    rdfs:domain cmpo:Wafer ;
    rdfs:range cmpo:WaferNotch ;
    rdfs:comment "Identifies the type of alignment feature on the wafer edge."@en .

cmpo:isStateOf a owl:ObjectProperty ;
    rdfs:label "is state of"@en ;
    rdfs:domain cmpo:WaferState ;
    rdfs:range cmpo:Wafer ;
    rdfs:comment "Connects a wafer state to the wafer it describes."@en .

cmpo:hasDefectType a owl:ObjectProperty ;
    rdfs:label "has defect type"@en ;
    rdfs:domain cmpo:WaferState ;
    rdfs:range cmpo:DefectType ;
    rdfs:comment "Associates a detected defect type with a wafer state."@en .

cmpo:isSpecifiedBy a owl:ObjectProperty ;
    rdfs:label "is specified by"@en ;
    rdfs:domain cmpo:Wafer ;
    rdfs:range cmpo:ProcessCard ;
    rdfs:comment "Links a wafer to the process card that specifies its planned processing and target values."@en .

cmpo:hasInput a owl:ObjectProperty ;
    rdfs:label "has input"@en ;
    rdfs:domain cmpo:PolishingStep ;
    rdfs:range cmpo:Wafer ;
    rdfs:comment "The wafer entering a processing step."@en .

cmpo:hasOutput a owl:ObjectProperty ;
    rdfs:label "has output"@en ;
    rdfs:domain cmpo:PolishingStep ;
    rdfs:range cmpo:Wafer ;
    rdfs:comment "The wafer leaving a processing step."@en .

cmpo:executedOn a owl:ObjectProperty ;
    rdfs:label "executed on"@en ;
    rdfs:domain cmpo:PolishingStep ;
    rdfs:range cmpo:Tool ;
    rdfs:comment "The tool on which a step is executed, as recorded by the process card or MES."@en .

cmpo:runsOnPlaten a owl:ObjectProperty ;
    rdfs:label "runs on platen"@en ;
    rdfs:domain cmpo:PolishingStep ;
    rdfs:range cmpo:Platen ;
    rdfs:comment "The physical platen a step executes on; critical for multi-platen CMP tools."@en .

cmpo:hasNextStep a owl:ObjectProperty ;
    rdfs:label "has next step"@en ;
    rdfs:domain cmpo:PolishingStep ;
    rdfs:range cmpo:PolishingStep ;
    rdfs:comment "Links a step to the immediately following step, enabling traversal of the process workflow."@en .

cmpo:partOfService a owl:ObjectProperty ;
    rdfs:label "part of service"@en ;
    rdfs:domain cmpo:PolishingStep ;
    rdfs:range cmpo:Service ;
    rdfs:comment "Assigns a step to the production service (e.g. CMP) it belongs to."@en .

cmpo:targetsSide a owl:ObjectProperty ;
    rdfs:label "targets side"@en ;
    rdfs:domain cmpo:PolishingStep ;
    rdfs:range cmpo:WaferSide ;
    rdfs:comment "Defines which wafer side a step processes."@en .

cmpo:usesRecipe a owl:ObjectProperty ;
    rdfs:label "uses recipe"@en ;
    rdfs:domain cmpo:PolishingStep ;
    rdfs:range cmpo:Recipe ;
    rdfs:comment "The recipe (procedure) governing a step's set-points."@en .

cmpo:hasSetPointInstruction a owl:ObjectProperty ;
    rdfs:label "has set-point instruction"@en ;
    rdfs:domain cmpo:Recipe ;
    rdfs:range cmpo:SetPoint ;
    rdfs:comment "Links a recipe to one of its set-point instructions."@en .

cmpo:setPointOf a owl:ObjectProperty ;
    rdfs:label "set-point of"@en ;
    rdfs:domain cmpo:SetPoint ;
    rdfs:range cmpo:CMPParameter ;
    rdfs:comment "The observable parameter this set-point targets."@en .

cmpo:hasPolishingMode a owl:ObjectProperty ;
    rdfs:label "has polishing mode"@en ;
    rdfs:domain cmpo:PolishingStep ;
    rdfs:range cmpo:PolishingMode ;
    rdfs:comment "Specifies the functional polishing mode of a step within the planarisation sequence."@en .

cmpo:usesEPDMethod a owl:ObjectProperty ;
    rdfs:label "uses EPD method"@en ;
    rdfs:domain cmpo:PolishingStep ;
    rdfs:range cmpo:EPDMethod ;
    rdfs:comment "The end-point detection method employed for a polishing step."@en .

cmpo:hasCleaningStep a owl:ObjectProperty ;
    rdfs:label "has cleaning step"@en ;
    rdfs:domain cmpo:PolishingStep ;
    rdfs:range cmpo:PostCMPCleaning ;
    rdfs:comment "Links a polishing step to its post-CMP cleaning process."@en .

cmpo:hasToolComponent a owl:ObjectProperty ;
    rdfs:label "has tool component"@en ;
    rdfs:domain cmpo:Tool ;
    rdfs:range cmpo:ToolComponent ;
    rdfs:comment "Connects a tool to one of its physical components (platen, carrier, conditioner, chamber, slurry pipe)."@en .

cmpo:hasToolType a owl:ObjectProperty ;
    rdfs:label "has tool type"@en ;
    rdfs:domain cmpo:Tool ;
    rdfs:range cmpo:CMPToolType ;
    rdfs:comment "Classifies a CMP tool by its kinematic configuration (rotary, linear, orbital)."@en .

cmpo:undergoesQualification a owl:ObjectProperty ;
    rdfs:label "undergoes qualification"@en ;
    rdfs:domain cmpo:Tool ;
    rdfs:range cmpo:ToolQualification ;
    rdfs:comment "Links a tool to a qualification process it undergoes."@en .

cmpo:hasPressureZone a owl:ObjectProperty ;
    rdfs:label "has pressure zone"@en ;
    rdfs:domain cmpo:Carrier ;
    rdfs:range cmpo:PressureZone ;
    rdfs:comment "A carrier may have multiple independently pressurized zones; number and configuration depend on the tool."@en .

cmpo:hasMotionProfile a owl:ObjectProperty ;
    rdfs:label "has motion profile"@en ;
    rdfs:domain cmpo:Carrier ;
    rdfs:range cmpo:MotionProfile ;
    rdfs:comment "Defines the motion pattern applied by the carrier."@en .

cmpo:hasPolishingPad a owl:ObjectProperty ;
    owl:inverseOf cmpo:isMountedOn ;
    rdfs:label "has polishing pad"@en ;
    rdfs:domain cmpo:Platen ;
    rdfs:range cmpo:PolishingPad ;
    rdfs:comment "The polishing pad currently mounted on a platen."@en .

cmpo:isMountedOn a owl:ObjectProperty ;
    rdfs:label "is mounted on"@en ;
    rdfs:domain cmpo:PolishingPad ;
    rdfs:range cmpo:Platen ;
    rdfs:comment "Relates a polishing pad to the platen it is currently attached to."@en .

cmpo:hasGroovePattern a owl:ObjectProperty ;
    rdfs:label "has groove pattern"@en ;
    rdfs:domain cmpo:PolishingPad ;
    rdfs:range cmpo:GroovePattern ;
    rdfs:comment "Specifies the groove geometry of a polishing pad."@en .

cmpo:conditionsPad a owl:ObjectProperty ;
    rdfs:label "conditions pad"@en ;
    rdfs:domain cmpo:Conditioner ;
    rdfs:range cmpo:PolishingPad ;
    rdfs:comment "The pad this conditioner regenerates; conditioning happens during or between polishing steps."@en .

cmpo:hasConditionerDisc a owl:ObjectProperty ;
    rdfs:label "has conditioner disc"@en ;
    rdfs:domain cmpo:Conditioner ;
    rdfs:range cmpo:ConditionerDisc ;
    rdfs:comment "Links the conditioner arm to its replaceable diamond conditioning disc."@en .

cmpo:isDeliveredBy a owl:ObjectProperty ;
    rdfs:label "is delivered by"@en ;
    rdfs:range cmpo:SlurryPipe ;
    rdfs:comment "Connects a slurry or DI water supply to the slurry pipe that delivers it. Domain intentionally open (Slurry or DiWater)."@en .

cmpo:usedSlurry a owl:ObjectProperty ;
    rdfs:label "used slurry"@en ;
    rdfs:domain cmpo:PolishingStep ;
    rdfs:range cmpo:Slurry ;
    rdfs:comment "The slurry formulation used during a polishing step."@en .

cmpo:hasChemistry a owl:ObjectProperty ;
    rdfs:label "has chemistry"@en ;
    rdfs:domain cmpo:Slurry ;
    rdfs:range cmpo:SlurryChemistry ;
    rdfs:comment "Links a slurry to its chemical composition description."@en .

cmpo:hasAbrasiveType a owl:ObjectProperty ;
    rdfs:label "has abrasive type"@en ;
    rdfs:domain cmpo:Slurry ;
    rdfs:range cmpo:AbrasiveType ;
    rdfs:comment "Specifies the abrasive particle material of the slurry."@en .

cmpo:hasAdditive a owl:ObjectProperty ;
    rdfs:label "has additive"@en ;
    rdfs:domain cmpo:Slurry ;
    rdfs:range cmpo:ChemicalAdditive ;
    rdfs:comment "Connects a slurry formulation to one of its chemical additives."@en .

cmpo:tracksComponent a owl:ObjectProperty ;
    rdfs:label "tracks component"@en ;
    rdfs:domain cmpo:UsageTracking ;
    rdfs:range cmpo:ToolComponent ;
    rdfs:comment "Connects a usage-tracking record with the physical component it tracks."@en .

cmpo:hasProcessWindow a owl:ObjectProperty ;
    rdfs:label "has process window"@en ;
    rdfs:domain cmpo:CMPParameter ;
    rdfs:range cmpo:ProcessWindow ;
    rdfs:comment "The valid operating range of a parameter."@en .

cmpo:hasSPCLimit a owl:ObjectProperty ;
    rdfs:label "has SPC limit"@en ;
    rdfs:domain cmpo:CMPParameter ;
    rdfs:range cmpo:SPCLimit ;
    rdfs:comment "Associates a parameter with its SPC control and specification limits."@en .

cmpo:usesRTRControl a owl:ObjectProperty ;
    rdfs:label "uses run-to-run control"@en ;
    rdfs:domain cmpo:PolishingStep ;
    rdfs:range cmpo:RunToRunControl ;
    rdfs:comment "Indicates that a step is governed by a run-to-run APC strategy."@en .

cmpo:hasFeedbackParameter a owl:ObjectProperty ;
    rdfs:label "has feedback parameter"@en ;
    rdfs:domain cmpo:RunToRunControl ;
    rdfs:range cmpo:CMPParameter ;
    rdfs:comment "The measured output parameter used as feedback signal by the R2R controller (e.g. post-CMP thickness)."@en .

cmpo:hasFeedforwardParameter a owl:ObjectProperty ;
    rdfs:label "has feedforward parameter"@en ;
    rdfs:domain cmpo:RunToRunControl ;
    rdfs:range cmpo:CMPParameter ;
    rdfs:comment "The recipe set-point parameter adjusted by the R2R controller between runs (e.g. polishing time, downforce)."@en .

cmpo:usesPrestonModel a owl:ObjectProperty ;
    rdfs:label "uses Preston model"@en ;
    rdfs:domain cmpo:PolishingStep ;
    rdfs:range cmpo:PrestonModel ;
    rdfs:comment "Links a polishing step to its Preston equation model instance for MRR prediction."@en .

cmpo:hasSelectivity a owl:ObjectProperty ;
    rdfs:label "has selectivity"@en ;
    rdfs:domain cmpo:PolishingStep ;
    rdfs:range cmpo:MaterialSelectivity ;
    rdfs:comment "Associates a polishing step with its material selectivity characterisation."@en .

cmpo:primaryMaterial a owl:ObjectProperty ;
    rdfs:label "primary material"@en ;
    rdfs:domain cmpo:MaterialSelectivity ;
    rdfs:range cmpo:Material ;
    rdfs:comment "The material being preferentially removed (numerator of the selectivity ratio)."@en .

cmpo:secondaryMaterial a owl:ObjectProperty ;
    rdfs:label "secondary material"@en ;
    rdfs:domain cmpo:MaterialSelectivity ;
    rdfs:range cmpo:Material ;
    rdfs:comment "The reference or stop-layer material (denominator of the selectivity ratio)."@en .

cmpo:hasRole a owl:ObjectProperty ;
    rdfs:label "has role"@en ;
    rdfs:domain cmpo:Agent ;
    rdfs:range cmpo:Role ;
    rdfs:comment "Assigns a role (e.g. project owner, process owner) to an agent."@en .

cmpo:responsibleFor a owl:ObjectProperty ;
    rdfs:label "responsible for"@en ;
    rdfs:domain cmpo:Agent ;
    rdfs:comment "Connects an agent to the lot, project, tool or process it is responsible for. Range intentionally open."@en .

#################################################################
### 12. DATATYPE PROPERTIES
#################################################################

cmpo:hasLotNumber a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "has lot number"@en ;
    rdfs:domain cmpo:Lot ;
    rdfs:range xsd:string ;
    rdfs:comment "The lot number of a wafer lot, formatted like 400-111."@en .

cmpo:lotSize a owl:DatatypeProperty ;
    rdfs:label "lot size"@en ;
    rdfs:domain cmpo:Lot ;
    rdfs:range xsd:integer ;
    rdfs:comment "Total number of wafer slots in the lot; typically 25."@en .

cmpo:hasProjectName a owl:DatatypeProperty ;
    rdfs:label "has project name"@en ;
    rdfs:domain cmpo:Project ;
    rdfs:range xsd:string ;
    rdfs:comment "Name or number of the project a wafer or lot belongs to (e.g. XENA; Dummy for dummy wafers)."@en .

cmpo:diameter a owl:DatatypeProperty ;
    rdfs:label "diameter"@en ;
    rdfs:domain cmpo:Wafer ;
    rdfs:range xsd:float ;
    rdfs:comment "Wafer diameter in millimeters; most common: 150 mm (6 in), 200 mm (8 in), 300 mm (12 in)."@en .

cmpo:thickness a owl:DatatypeProperty ;
    rdfs:label "thickness"@en ;
    rdfs:range xsd:float ;
    rdfs:comment "Thickness value of a wafer or layer, in the unit given by the context (typically µm for wafers, nm for layers). Domain intentionally open (Wafer or Layer)."@en .

cmpo:hasStatus a owl:DatatypeProperty ;
    rdfs:label "has status"@en ;
    rdfs:domain cmpo:Wafer ;
    rdfs:range xsd:string ;
    rdfs:comment "Processing status code of a wafer (see cmpo:WaferStatus for the encoding)."@en .

cmpo:orientationPlane a owl:DatatypeProperty ;
    rdfs:label "orientation plane"@en ;
    rdfs:domain cmpo:CrystallographicOrientation ;
    rdfs:range xsd:string ;
    rdfs:comment "Miller indices of the wafer surface orientation (e.g. '100', '111')."@en .

cmpo:edgeExclusion a owl:DatatypeProperty ;
    rdfs:label "edge exclusion"@en ;
    rdfs:domain cmpo:Wafer ;
    rdfs:range xsd:float ;
    rdfs:comment "Width of the annular zone at the wafer edge (mm) excluded from process specifications and metrology; typically 2–5 mm."@en .

cmpo:hasMaterialName a owl:DatatypeProperty ;
    rdfs:label "has material name"@en ;
    rdfs:domain cmpo:Material ;
    rdfs:range xsd:string ;
    rdfs:comment "Name of a material (e.g. Silicon, Copper, SiO2)."@en .

cmpo:defectArea a owl:DatatypeProperty ;
    rdfs:label "defect area"@en ;
    rdfs:domain cmpo:DefectType ;
    rdfs:range xsd:float ;
    rdfs:comment "Area of a defect in square micrometers."@en .

cmpo:actualRemovalAmount a owl:DatatypeProperty ;
    rdfs:label "actual removal amount"@en ;
    rdfs:domain cmpo:WaferState ;
    rdfs:range xsd:float ;
    rdfs:comment "Actual thickness of material removed after CMP, in nm; computed from pre- and post-CMP thickness measurements."@en .

cmpo:stepIndex a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "step index"@en ;
    rdfs:domain cmpo:PolishingStep ;
    rdfs:range xsd:integer ;
    rdfs:comment "1-based ordering of a step within its parent service; enables reconstruction of multi-step workflows."@en .

cmpo:stageLabel a owl:DatatypeProperty ;
    skos:altLabel "STAGE"@en ;
    rdfs:label "stage label"@en ;
    rdfs:domain cmpo:PolishingStep ;
    rdfs:range xsd:string ;
    rdfs:comment "Stage identifier of the step as used in the PHM 2016 dataset (e.g. 'A' or 'B')."@en .

cmpo:polishingDuration a owl:DatatypeProperty ;
    rdfs:label "polishing duration"@en ;
    rdfs:domain cmpo:PolishingStep ;
    rdfs:range xsd:float ;
    rdfs:comment "Total time of the polishing step, in seconds."@en .

cmpo:polishingStartTime a owl:DatatypeProperty ;
    rdfs:label "polishing start time"@en ;
    rdfs:domain cmpo:PolishingStep ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "Timestamp at which the polishing step started."@en .

cmpo:polishingEndTime a owl:DatatypeProperty ;
    rdfs:label "polishing end time"@en ;
    rdfs:domain cmpo:PolishingStep ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "Timestamp at which the polishing step ended."@en .

cmpo:dwellTime a owl:DatatypeProperty ;
    rdfs:label "dwell time"@en ;
    rdfs:domain cmpo:PolishingStep ;
    rdfs:range xsd:float ;
    rdfs:comment "Time in seconds the wafer spends on the polishing pad during a single pass."@en .

cmpo:prestonCoefficient a owl:DatatypeProperty ;
    rdfs:label "Preston coefficient"@en ;
    rdfs:domain cmpo:PrestonModel ;
    rdfs:range xsd:float ;
    rdfs:comment "Preston coefficient k_p (unit 1/Pa); depends on pad, slurry and material combination. Higher k_p means more aggressive removal per unit of pressure × velocity."@en .

cmpo:derivationFormula a owl:DatatypeProperty ;
    rdfs:label "derivation formula"@en ;
    rdfs:domain cmpo:PrestonModel ;
    rdfs:range xsd:string ;
    rdfs:comment "Human-readable formula describing how a derived quantity is computed (e.g. 'MRR = k_p * P * V')."@en .

cmpo:selectivityRatio a owl:DatatypeProperty ;
    rdfs:label "selectivity ratio"@en ;
    rdfs:domain cmpo:MaterialSelectivity ;
    rdfs:range xsd:float ;
    rdfs:comment "Removal-rate ratio of primary to reference material (e.g. Cu:SiO2 = 10.0 means Cu is removed 10× faster)."@en .

cmpo:toolId a owl:DatatypeProperty ;
    skos:altLabel "MACHINE_ID"@en ;
    rdfs:label "tool ID"@en ;
    rdfs:domain cmpo:Tool ;
    rdfs:range xsd:string ;
    rdfs:comment "Identifier of a specific tool (e.g. 'CMP_Tool_001'; machine numbers in the PHM 2016 dataset)."@en .

cmpo:chamberNumber a owl:DatatypeProperty ;
    skos:altLabel "CHAMBER"@en ;
    rdfs:label "chamber number"@en ;
    rdfs:domain cmpo:Chamber ;
    rdfs:range xsd:integer ;
    rdfs:comment "Number of the processing chamber within a tool. Not the pressure chambers in the carrier."@en .

cmpo:qualificationStatus a owl:DatatypeProperty ;
    rdfs:label "qualification status"@en ;
    rdfs:domain cmpo:Tool ;
    rdfs:range xsd:string ;
    rdfs:comment "Status of tool qualification: Qualified, In-Progress or Not-Qualified."@en .

cmpo:seasoningDate a owl:DatatypeProperty ;
    rdfs:label "seasoning date"@en ;
    rdfs:domain cmpo:Tool ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "Date the tool underwent its initial seasoning/break-in process."@en .

cmpo:zonePosition a owl:DatatypeProperty ;
    rdfs:label "zone position"@en ;
    rdfs:domain cmpo:PressureZone ;
    rdfs:range xsd:integer ;
    rdfs:comment "Positional index of a pressure zone within the carrier."@en .

cmpo:padType a owl:DatatypeProperty ;
    rdfs:label "pad type"@en ;
    rdfs:domain cmpo:PolishingPad ;
    rdfs:range xsd:string ;
    rdfs:comment "Commercial name of the polishing pad (e.g. IC1000, Politex); determines mechanical and tribological characteristics."@en .

cmpo:padHardness a owl:DatatypeProperty ;
    rdfs:label "pad hardness"@en ;
    rdfs:domain cmpo:PolishingPad ;
    rdfs:range xsd:float ;
    rdfs:comment "Shore D hardness of the pad. Harder pads (~60) give better global planarisation; softer pads (~40) lower scratch defectivity."@en .

cmpo:padCompressibility a owl:DatatypeProperty ;
    rdfs:label "pad compressibility"@en ;
    rdfs:domain cmpo:PolishingPad ;
    rdfs:range xsd:float ;
    rdfs:comment "Percentage compressibility of the pad under standard load; affects contact area and pressure uniformity."@en .

cmpo:padLifetimeWaferCount a owl:DatatypeProperty ;
    rdfs:label "pad lifetime wafer count"@en ;
    rdfs:domain cmpo:PolishingPad ;
    rdfs:range xsd:integer ;
    rdfs:comment "Maximum number of wafers processable on this pad before replacement."@en .

cmpo:padLifetimeMinutes a owl:DatatypeProperty ;
    rdfs:label "pad lifetime minutes"@en ;
    rdfs:domain cmpo:PolishingPad ;
    rdfs:range xsd:float ;
    rdfs:comment "Total accumulated polishing time (minutes) allowed for this pad before replacement."@en .

cmpo:grooveDepth a owl:DatatypeProperty ;
    rdfs:label "groove depth"@en ;
    rdfs:domain cmpo:GroovePattern ;
    rdfs:range xsd:float ;
    rdfs:comment "Depth of the pad grooves in millimeters; decreases with wear and triggers pad replacement below a threshold."@en .

cmpo:grooveWidth a owl:DatatypeProperty ;
    rdfs:label "groove width"@en ;
    rdfs:domain cmpo:GroovePattern ;
    rdfs:range xsd:float ;
    rdfs:comment "Width of the pad grooves in millimeters."@en .

cmpo:discDiamondGrade a owl:DatatypeProperty ;
    rdfs:label "disc diamond grade"@en ;
    rdfs:domain cmpo:ConditionerDisc ;
    rdfs:range xsd:string ;
    rdfs:comment "Grit grade or mesh size of the embedded diamond particles (e.g. '#100'); finer grit gives smoother pad surface."@en .

cmpo:conditioningMode a owl:DatatypeProperty ;
    rdfs:label "conditioning mode"@en ;
    rdfs:domain cmpo:Conditioner ;
    rdfs:range xsd:string ;
    rdfs:comment "Mode of pad conditioning: in-situ (concurrent with polishing) or ex-situ (between runs)."@en .

cmpo:hasLifetime a owl:DatatypeProperty ;
    rdfs:label "has lifetime"@en ;
    rdfs:domain cmpo:Consumable ;
    rdfs:range xsd:string ;
    rdfs:comment "Specified service life of a consumable."@en .

cmpo:slurryName a owl:DatatypeProperty ;
    rdfs:label "slurry name"@en ;
    rdfs:domain cmpo:Slurry ;
    rdfs:range xsd:string ;
    rdfs:comment "Commercial name of the slurry, e.g. KLEBOSOL."@en .

cmpo:slurryBatch a owl:DatatypeProperty ;
    rdfs:label "slurry batch"@en ;
    rdfs:domain cmpo:Slurry ;
    rdfs:range xsd:string ;
    rdfs:comment "Batch or charge identifier of the slurry."@en .

cmpo:slurryDilutionRatio a owl:DatatypeProperty ;
    rdfs:label "slurry dilution ratio"@en ;
    rdfs:domain cmpo:Slurry ;
    rdfs:range xsd:float ;
    rdfs:comment "Ratio of slurry concentrate volume to total volume after DI-water dilution (e.g. 0.5 = 1:1)."@en .

cmpo:additiveConcentration a owl:DatatypeProperty ;
    rdfs:label "additive concentration"@en ;
    rdfs:domain cmpo:ChemicalAdditive ;
    rdfs:range xsd:float ;
    rdfs:comment "Concentration of the additive in the slurry solution (% by weight or volume)."@en .

cmpo:epdThreshold a owl:DatatypeProperty ;
    rdfs:label "EPD threshold"@en ;
    rdfs:domain cmpo:EndPointDetection ;
    rdfs:range xsd:float ;
    rdfs:comment "Threshold value used to determine the end of polishing."@en .

cmpo:cleaningDuration a owl:DatatypeProperty ;
    rdfs:label "cleaning duration"@en ;
    rdfs:domain cmpo:PostCMPCleaning ;
    rdfs:range xsd:float ;
    rdfs:comment "Duration of the post-CMP cleaning process, in seconds."@en .

cmpo:cleaningTemperature a owl:DatatypeProperty ;
    rdfs:label "cleaning temperature"@en ;
    rdfs:domain cmpo:PostCMPCleaning ;
    rdfs:range xsd:float ;
    rdfs:comment "Temperature of the cleaning solution, in degrees Celsius."@en .

cmpo:targetLayerThickness a owl:DatatypeProperty ;
    rdfs:label "target layer thickness"@en ;
    rdfs:domain cmpo:ProcessCard ;
    rdfs:range xsd:float ;
    rdfs:comment "Target thickness of the layer after processing, as specified on the process card."@en .

cmpo:targetRemovalAmount a owl:DatatypeProperty ;
    rdfs:label "target removal amount"@en ;
    rdfs:domain cmpo:ProcessCard ;
    rdfs:range xsd:float ;
    rdfs:comment "Nominal thickness of material to be removed during the CMP step, in nm, as defined on the process card."@en .

cmpo:targetUniformity a owl:DatatypeProperty ;
    rdfs:label "target uniformity"@en ;
    rdfs:domain cmpo:ProcessCard ;
    rdfs:range xsd:float ;
    rdfs:comment "Target within-wafer or die-to-die uniformity specification, as percentage or absolute value."@en .

cmpo:uniformityTolerance a owl:DatatypeProperty ;
    rdfs:label "uniformity tolerance"@en ;
    rdfs:domain cmpo:ProcessCard ;
    rdfs:range xsd:float ;
    rdfs:comment "Acceptable tolerance for thickness uniformity across the wafer (±%)."@en .

cmpo:setPointValue a owl:DatatypeProperty ;
    rdfs:label "set-point value"@en ;
    rdfs:domain cmpo:SetPoint ;
    rdfs:range xsd:float ;
    rdfs:comment "The target numeric value of a recipe set-point instruction."@en .

cmpo:windowMinValue a owl:DatatypeProperty ;
    rdfs:label "window minimum value"@en ;
    rdfs:domain cmpo:ProcessWindow ;
    rdfs:range xsd:float ;
    rdfs:comment "Lower bound of the process window."@en .

cmpo:windowMaxValue a owl:DatatypeProperty ;
    rdfs:label "window maximum value"@en ;
    rdfs:domain cmpo:ProcessWindow ;
    rdfs:range xsd:float ;
    rdfs:comment "Upper bound of the process window."@en .

cmpo:upperControlLimit a owl:DatatypeProperty ;
    rdfs:label "upper control limit"@en ;
    rdfs:domain cmpo:SPCLimit ;
    rdfs:range xsd:float ;
    rdfs:comment "Upper Control Limit (+3σ); exceeding it triggers a process investigation."@en .

cmpo:lowerControlLimit a owl:DatatypeProperty ;
    rdfs:label "lower control limit"@en ;
    rdfs:domain cmpo:SPCLimit ;
    rdfs:range xsd:float ;
    rdfs:comment "Lower Control Limit (−3σ); values below it trigger a process investigation."@en .

cmpo:upperSpecLimit a owl:DatatypeProperty ;
    rdfs:label "upper specification limit"@en ;
    rdfs:domain cmpo:SPCLimit ;
    rdfs:range xsd:float ;
    rdfs:comment "Upper Specification Limit; wafers exceeding it are non-conforming."@en .

cmpo:lowerSpecLimit a owl:DatatypeProperty ;
    rdfs:label "lower specification limit"@en ;
    rdfs:domain cmpo:SPCLimit ;
    rdfs:range xsd:float ;
    rdfs:comment "Lower Specification Limit; wafers below it are non-conforming."@en .

cmpo:spcTargetValue a owl:DatatypeProperty ;
    rdfs:label "SPC target value"@en ;
    rdfs:domain cmpo:SPCLimit ;
    rdfs:range xsd:float ;
    rdfs:comment "Nominal target value of the monitored parameter; centre of the SPC chart."@en .

cmpo:usageId a owl:DatatypeProperty ;
    rdfs:label "usage ID"@en ;
    rdfs:domain cmpo:UsageTracking ;
    rdfs:range xsd:string ;
    rdfs:comment "Unique identifier of a usage-tracking record."@en .

cmpo:usageType a owl:DatatypeProperty ;
    rdfs:label "usage type"@en ;
    rdfs:domain cmpo:UsageTracking ;
    rdfs:range xsd:string ;
    rdfs:comment "Type of tracked usage, e.g. Polishing or Conditioning."@en .

cmpo:usageTime a owl:DatatypeProperty ;
    rdfs:label "usage time"@en ;
    rdfs:domain cmpo:UsageTracking ;
    rdfs:range xsd:float ;
    rdfs:comment "Accumulated usage time of the tracked component."@en .

cmpo:usageCount a owl:DatatypeProperty ;
    rdfs:label "usage count"@en ;
    rdfs:domain cmpo:UsageTracking ;
    rdfs:range xsd:float ;
    rdfs:comment "Accumulated usage count of the tracked component."@en .

cmpo:agentName a owl:DatatypeProperty ;
    rdfs:label "agent name"@en ;
    rdfs:domain cmpo:Agent ;
    rdfs:range xsd:string ;
    rdfs:comment "Name of the person or organizational actor."@en .

cmpo:machineDataId a owl:DatatypeProperty ;
    rdfs:label "machine data ID"@en ;
    skos:altLabel "MACHINE_DATA"@en ;
    rdfs:domain cmpo:CMPObservation ;
    rdfs:range xsd:integer ;
    rdfs:comment "Identifier of the machine data acquisition unit that produced the record, as given in the PHM 2016 MACHINE_DATA column (values 1-6). The exact physical semantics are dataset-specific; kept as a traceability attribute on observations."@en .

### Added in v2.0.2 (see changelog P5)
cmpo:madeOnPlatform a owl:ObjectProperty ;
    rdfs:label "made on platform"@en ;
    rdfs:comment "Links an observation to the tool or tool component on which it was made. CMP-specific extension of the SOSA/SSN pattern: PHM 2016 tool logs name tools and chambers rather than individual sensors, so observations link directly to equipment instead of via sosa:madeBySensor."@en ;
    rdfs:domain cmpo:CMPObservation ;
    rdfs:range cmpo:Equipment ;
    rdfs:seeAlso sosa:madeBySensor .
